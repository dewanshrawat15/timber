{
  "version": "1.0",
  "name": "Gallery",
  "root": {
    "type": "Column",
    "key": "root",
    "styling": { "className": "p-6 gap-4 bg-gray-50 min-h-screen" },
    "children": [
      {
        "type": "Text",
        "key": "gallery-heading",
        "props": { "as": "h1" },
        "styling": { "className": "text-2xl font-bold text-gray-900" },
        "children": "Photo Gallery"
      },
      {
        "type": "Grid",
        "key": "gallery-grid",
        "props": { "cols": 3, "gap": "gap-4" },
        "children": [
          {
            "type": "Card",
            "key": "img-card-1",
            "props": { "shadow": "sm" },
            "styling": { "className": "overflow-hidden p-0" },
            "children": [
              {
                "type": "Image",
                "key": "img-1",
                "props": {
                  "src": "https://picsum.photos/seed/timber1/600/400",
                  "alt": "Gallery image 1",
                  "objectFit": "cover"
                },
                "styling": { "className": "w-full h-48 rounded-xl" }
              }
            ]
          },
          {
